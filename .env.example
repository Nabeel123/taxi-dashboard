# Copy to .env.local (never commit .env*.local).

# GA4 Data API (server): numeric Property ID from GA → Admin → Property settings
GA4_PROPERTY_ID=

# Optional: web stream measurement id (G-…) for labels + Admin API auto-match
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# GA4 (preferred): full GCP service-account JSON as one line; use \n inside private_key.
# Optional outer quotes are stripped if your loader includes them.
# GOOGLE_SERVICE_ACCOUNT_G_ANALYTICS={"type":"service_account",...}

# Fallback: general Google service account JSON (same shape) if G_ANALYTICS is unset
# GOOGLE_SERVICE_ACCOUNT={"type":"service_account",...}

# Optional: local dev — absolute path to a key JSON file (ADC)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/key.json
